<!DOCTYPE html>
<html lang="th">

<head>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Courts</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            background: #f3f4f6;
            font-family: Inter, system-ui, sans-serif;
            color: #111827;
        }

        .topbar {
            background: white;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 0;
            margin-bottom: 24px;
        }

        .page-card {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 18px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, .04);
        }

        .court-card {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, .04);
        }

        .court-card .card-body {
            padding: 18px;
            position: relative;
        }

        .btn-green {
            background: #16a34a;
            border: none;
            color: white;
        }

        .btn-green:hover {
            background: #15803d;
            color: white;
        }

        .btn-soft {
            border-radius: 14px;
            padding: 10px 16px;
            font-weight: 600;
        }

        .court-title {
            font-size: 1.35rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .lang-switch button,
        .lang-switch a,
        .lang-switch select {
            border-radius: 10px !important;
        }

        .footer {
            padding: 20px;
            text-align: center;
            color: #6b7280;
            font-size: .9rem;
        }
    </style>
</head>

<body>

    <div class="topbar">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-trophy text-success"></i>
                <h4 class="mb-0 fw-bold" data-i18n="courts-title">คอร์ด</h4>
            </div>

            <div class="d-flex align-items-center gap-2 lang-switch">
                <a href="/history" class="btn btn-light border btn-sm">
                    <i class="bi bi-clock-history"></i>
                </a>

                <select id="langSelect" class="form-select form-select-sm w-auto d-inline"
                    onchange="setLanguage(this.value)">
                    <option value="th">TH</option>
                    <option value="en">EN</option>
                </select>
            </div>
        </div>
    </div>

    <div class="container">

        <div class="page-card mb-4">
            <form action="/courts/add" method="POST" id="addCourtForm">
                <div class="d-flex gap-3 flex-column flex-md-row">
                    <input name="name" class="form-control form-control-lg"
                        placeholder="ชื่อคอร์ท"
                        data-i18n="court-name-placeholder" />

                    <input type="hidden" name="password" id="addCourtPassword" value="" />

                    <button type="button" id="setPasswordBtn"
                        class="btn btn-outline-warning btn-lg px-3 btn-soft text-nowrap"
                        data-i18n="set-password-btn">
                        <i class="bi bi-key"></i> ตั้งรหัสผ่าน
                    </button>

                    <button class="btn btn-green btn-lg px-4 btn-soft" data-i18n="add-court-btn">
                        <i class="bi bi-plus-lg"></i>
                        เพิ่ม
                    </button>
                </div>
            </form>
        </div>

        <div class="row g-4">
            <% if (!courts || courts.length===0) { %>
                <div class="col-12">
                    <div class="alert alert-secondary text-center rounded-4">
                        ไม่มีคอร์ทในระบบ
                    </div>
                </div>
            <% } else { %>
                <% courts.forEach(c=> { %>
                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="court-card h-100">
                            <div class="card-body d-flex flex-column">
                                <div class="badge bg-info position-absolute top-0 end-0 m-2" data-i18n="pair-counter" data-i18n-value="<%= c.pairs %>"><%= c.pairs %></div>
                                <div class="court-title">
                                    <% if (c.password) { %>
                                        <i class="bi bi-lock-fill text-warning me-2"></i>
                                    <% } %>
                                    <%= c.name %>
                                </div>

                                <% if (c.password) { %>
                                    <button data-open-court="<%= c.id %>"
                                       class="btn btn-green btn-soft w-100 mb-2" data-i18n="open-court-btn">
                                        <i class="bi bi-box-arrow-up-right"></i> เปิด
                                    </button>
                                <% } else { %>
                                    <a href="/court/<%= c.id %>"
                                       class="btn btn-green btn-soft w-100 mb-2" data-i18n="open-court-btn">
                                        <i class="bi bi-box-arrow-up-right"></i> เปิด
                                    </a>
                                <% } %>

                                <div class="d-flex gap-2 mt-1">
                                    <a href="/court/<%= c.id %>/history" data-i18n="history-btn"
                                        class="btn btn-light border flex-fill btn-soft" >
                                        <i class="bi bi-clock-history"></i>
                                        ดูประวัติแมตช์
                                    </a>

                                    <form action="/court/<%= c.id %>/delete" method="POST">
                                        <button type="submit"
                                            class="btn btn-outline-danger btn-soft"
                                            onclick="return confirm(t('delete-court-data'))">
                                            <i class="bi bi-trash"></i>
                                            <span data-i18n="delete-court-btn">ลบคอร์ด</span>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>

    <div class="footer">
        Made by <a href="https://github.com/chocolat30" target="_blank">P.Raccoon</a>
    </div>

    <div class="modal fade" id="passwordModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" data-i18n="password-modal-title">กรุณากรอกรหัสผ่าน</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="passwordForm" novalidate>
                    <div class="modal-body">
                        <input type="password" id="modalPassword" class="form-control"
                            maxlength="10" autocomplete="current-password"
                            data-i18n="password-modal-placeholder" />
                        <div id="passwordError" class="invalid-feedback d-none"
                            data-i18n="password-modal-error"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light border btn-soft"
                            data-bs-dismiss="modal" data-i18n="back-btn">ย้อนกลับ</button>
                        <button type="submit" class="btn btn-green btn-soft" data-i18n="password-modal-btn">
                            <i class="bi bi-unlock"></i> เปิดคอร์ท
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="setPasswordModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" data-i18n="set-password-modal-title">ตั้งรหัสผ่าน</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="password" id="setPasswordInput" class="form-control form-control-lg"
                        maxlength="10" autocomplete="new-password"
                        data-i18n="set-password-modal-placeholder" />
                    <div id="setPasswordHint" class="form-text mt-2" data-i18n="set-password-modal-hint"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="clearPasswordBtn" class="btn btn-outline-danger btn-soft me-auto">
                        <i class="bi bi-x-circle"></i> <span data-i18n="set-password-modal-clear">ลบรหัสผ่าน</span>
                    </button>
                    <button type="button" class="btn btn-light border btn-soft"
                        data-bs-dismiss="modal" data-i18n="back-btn">ย้อนกลับ</button>
                    <button type="button" id="savePasswordBtn" class="btn btn-green btn-soft">
                        <i class="bi bi-check-lg"></i> <span data-i18n="set-password-modal-save">ตกลง</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/i18n.js?v=<%= APP_VERSION %>"></script>
    <script>
    document.addEventListener('DOMContentLoaded', () => {

        const form = document.getElementById('passwordForm');
        const input = document.getElementById('modalPassword');
        const errorBox = document.getElementById('passwordError');
        const modal = document.getElementById('passwordModal');
        const passwordModal = bootstrap.Modal.getOrCreateInstance(modal);

        let currentCid = null;

        // Attach to all open buttons (lock icon + regular)
        document.querySelectorAll('[data-open-court]').forEach(btn => {
            btn.addEventListener('click', e => {
                e.preventDefault();
                currentCid = btn.dataset.openCourt;
                form.reset();
                errorBox.classList.add('d-none');
                input.classList.remove('is-invalid');
                passwordModal.show();
                setTimeout(() => input.focus(), 300);
            });
        });

        form.addEventListener('submit', async ev => {
            ev.preventDefault();
            const pw = input.value.trim();

            input.classList.remove('is-invalid');
            errorBox.classList.add('d-none');

            if (!pw) {
                input.classList.add('is-invalid');
                errorBox.textContent = t('password-modal-required');
                errorBox.classList.remove('d-none');
                return;
            }

            const submitBtn = form.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>' + t('password-modal-btn');

            try {
                const res = await fetch(`/court/${currentCid}/open`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ password: pw })
                });

                if (res.ok || res.redirected) {
                    const loc = res.headers.get('location') || `/court/${currentCid}`;
                    window.location.href = loc;
                    return;
                }

                const msg = await res.text();
                if (res.status === 403) {
                    input.classList.add('is-invalid');
                    errorBox.textContent = t('password-modal-error');
                    errorBox.classList.remove('d-none');
                    return;
                }

                throw new Error(msg || 'open_failed');
            } catch (err) {
                window.location.href = `/court/${currentCid}?msg=open_error`;
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="bi bi-unlock"></i> ' + t('password-modal-btn');
            }
        });

        // --- Set password modal (add court form) ---
        const setPasswordModalEl = document.getElementById('setPasswordModal');
        const setPasswordModal = bootstrap.Modal.getOrCreateInstance(setPasswordModalEl);
        const setPasswordInput = document.getElementById('setPasswordInput');
        const addCourtPassword = document.getElementById('addCourtPassword');
        const setPasswordBtn = document.getElementById('setPasswordBtn');
        const savePasswordBtn = document.getElementById('savePasswordBtn');
        const clearPasswordBtn = document.getElementById('clearPasswordBtn');

        function updateSetPasswordBtn() {
            if (addCourtPassword.value) {
                setPasswordBtn.innerHTML = '<i class="bi bi-lock-fill"></i> ' + t('set-password-btn');
                setPasswordBtn.classList.remove('btn-outline-warning');
                setPasswordBtn.classList.add('btn-warning');
            } else {
                setPasswordBtn.innerHTML = '<i class="bi bi-key"></i> ' + t('set-password-btn');
                setPasswordBtn.classList.remove('btn-warning');
                setPasswordBtn.classList.add('btn-outline-warning');
            }
        }

        setPasswordBtn.addEventListener('click', () => {
            setPasswordInput.value = addCourtPassword.value;
            setPasswordModal.show();
            setTimeout(() => setPasswordInput.focus(), 300);
        });

        savePasswordBtn.addEventListener('click', () => {
            const val = setPasswordInput.value.trim();
            addCourtPassword.value = val;
            updateSetPasswordBtn();
            setPasswordModal.hide();
        });

        clearPasswordBtn.addEventListener('click', () => {
            setPasswordInput.value = '';
            addCourtPassword.value = '';
            updateSetPasswordBtn();
            setPasswordModal.hide();
        });

        // Initialize button state
        updateSetPasswordBtn();
    });
    </script>
    </body>

    </html>
