<!DOCTYPE html>
<html lang="th">

<head>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Courts</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            background: #f3f4f6;
            font-family: Inter, system-ui, sans-serif;
            color: #111827;
        }

        .topbar {
            background: white;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 0;
            margin-bottom: 24px;
        }

        .page-card {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 18px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, .04);
        }

        .court-card {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, .04);
        }

        .court-card .card-body {
            padding: 18px;
            position: relative;
        }

        .btn-green {
            background: #16a34a;
            border: none;
            color: white;
        }

        .btn-green:hover {
            background: #15803d;
            color: white;
        }

        .btn-soft {
            border-radius: 14px;
            padding: 10px 16px;
            font-weight: 600;
        }

        .court-title {
            font-size: 1.35rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .lang-switch button,
        .lang-switch a,
        .lang-switch select {
            border-radius: 10px !important;
        }

        .footer {
            padding: 20px;
            text-align: center;
            color: #6b7280;
            font-size: .9rem;
        }
    </style>
</head>

<body>

    <div class="topbar">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-trophy text-success"></i>
                <h4 class="mb-0 fw-bold" data-i18n="courts-title">คอร์ด</h4>
            </div>

            <div class="d-flex align-items-center gap-2 lang-switch">
                <a href="/history" class="btn btn-light border btn-sm">
                    <i class="bi bi-clock-history"></i>
                </a>

                <select id="langSelect" class="form-select form-select-sm w-auto d-inline"
                    onchange="setLanguage(this.value)">
                    <option value="th">TH</option>
                    <option value="en">EN</option>
                </select>
            </div>
        </div>
    </div>

    <div class="container">

        <div class="page-card mb-4">
            <form action="/courts/add" method="POST">
                <div class="d-flex gap-3 flex-column flex-md-row">
                    <input name="name" class="form-control form-control-lg"
                        placeholder="ชื่อคอร์ท"
                        data-i18n="court-name-placeholder" />

                    <button class="btn btn-green btn-lg px-4 btn-soft" data-i18n="add-court-btn">
                        <i class="bi bi-plus-lg"></i>
                        เพิ่ม
                    </button>
                </div>
            </form>
        </div>

        <div class="row g-4">
            <% if (!courts || courts.length===0) { %>
                <div class="col-12">
                    <div class="alert alert-secondary text-center rounded-4">
                        ไม่มีคอร์ทในระบบ
                    </div>
                </div>
            <% } else { %>
                <% courts.forEach(c=> { %>
                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="court-card h-100">
                            <div class="card-body d-flex flex-column">
                                <div class="badge bg-info position-absolute top-0 end-0 m-2"
                                    data-i18n="pair-count"
                                    data-i18n-value="<%= c.pairs %>"><%= c.pairs %>
                                </div>
                                <div class="court-title"><%= c.name %></div>

                                <a href="/court/<%= c.id %>"
                                    class="btn btn-green btn-soft w-100 mb-2" data-i18n="open-court-btn">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                    เปิด
                                </a>

                                <div class="d-flex gap-2 mt-1">
                                    <a href="/court/<%= c.id %>/history" data-i18n="history-btn"
                                        class="btn btn-light border flex-fill btn-soft" >
                                        <i class="bi bi-clock-history"></i>
                                        ดูประวัติแมตช์
                                    </a>

                                    <form action="/court/<%= c.id %>/delete" method="POST">
                                        <button type="submit"
                                            class="btn btn-outline-danger btn-soft"
                                            onclick="return confirm(t('delete-court-data'))">
                                            <i class="bi bi-trash"></i>
                                            <span data-i18n="delete-court-btn">ลบคอร์ด</span>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>

    <div class="footer">
        Made by <a href="https://github.com/chocolat30" target="_blank">P.Raccoon</a>
    </div>

    <script src="/js/i18n.js"></script>
</body>

</html>
