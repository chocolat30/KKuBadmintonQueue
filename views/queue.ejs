<!DOCTYPE html>
<html>

<head>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>
    <%= court.name %> - คิว
  </title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
  <script src="https://cdn.socket.io/4.5.4/socket.io.min.js"></script>

  <style>
    body {
      background: #f3f4f6;
      font-family: Inter, system-ui, sans-serif;
      color: #111827;
    }

    .topbar {
      background: white;
      border-bottom: 1px solid #e5e7eb;
      padding: 14px 0;
      margin-bottom: 20px;
    }

    .glass-card {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 22px;
      box-shadow: 0 2px 10px rgba(0, 0, 0, .04);
    }

    .action-btn {
      border-radius: 16px;
      padding: 12px 20px;
      font-weight: 700;
      border-width: 2px;
      white-space: nowrap;
    }

    .team-panel {
      border-radius: 22px;
      padding: 22px;
      min-height: 240px;
    }

    .team-green {
      background: #edf9f0;
      border: 2px solid #4ade80;
    }

    .team-red {
      background: #fff1f2;
      border: 2px solid #f87171;
    }

    .score-row {
      display: flex;
      align-items: center;
      gap: 14px;
      margin: 18px 0;
    }

    .score-box {
      font-size: 2rem;
      font-weight: 800;
      min-width: 36px;
      text-align: center;
    }

    .score-btn {
      border-radius: 14px;
      width: 46px;
      height: 46px;
      font-size: 1.1rem;
      font-weight: 800;
    }

    .queue-item {
      padding: 18px;
      border-bottom: 1px solid #f0f0f0;
      user-select: none;
      transition: .2s;
    }

    .queue-item:last-child {
      border-bottom: none;
    }

    .queue-item.dragging {
      opacity: .5;
    }

    .queue-item.drag-over {
      background: #eff6ff;
    }

    .pill {
      background: #eef2ff;
      color: #4f46e5;
      border-radius: 999px;
      padding: 4px 12px;
      font-size: .85rem;
      font-weight: 700;
    }

    .drag-handle {
      cursor: grab;
      color: #9ca3af;
      touch-action: none;
    }

    .match-timer {
      font-weight: 700;
      color: #6b7280;
    }

    .offline-overlay {
      position: absolute;
      inset: 0;
      background: rgba(255, 255, 255, .9);
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 22px;
      z-index: 10;
    }

    .live-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: #22c55e;
      display: inline-block;
      animation: pulse 1.2s infinite;
    }

    @keyframes pulse {
      0% { opacity: 1; }
      50% { opacity: .4; }
      100% { opacity: 1; }
    }

    @media (max-width: 768px) {
      .action-stack {
        flex-direction: column;
      }

      .action-stack>* {
        width: 100%;
      }

      .team-panel {
        min-height: auto;
      }

      .score-box {
        font-size: 1.6rem;
      }

      .top-actions {
        flex-wrap: wrap;
        justify-content: end;
      }
    }
  </style>
</head>

<body>

  <div class="topbar">
    <div class="container d-flex justify-content-between align-items-center gap-3 flex-wrap">

      <div class="d-flex align-items-center gap-3">
        <a href="/" class="btn btn-light border rounded-4">
          <i class="bi bi-arrow-left"></i>
        </a>

        <div>
          <h2 class="fw-bold mb-0">
            <%= court.name %>
            <span class="live-dot" id="liveIndicator"></span>
  
          </h2>
        </div>
      </div>

      <div class="d-flex gap-2 align-items-center top-actions">
        <div id="courtQR" class="d-none"></div>
            <button id="showQRBtn" class="btn btn-light border rounded-4" type="button">QR Code</button>

        <a href="/court/<%= court.id %>/history" class="btn btn-light border rounded-4">
          <i class="bi bi-clock-history"></i>
        </a>

        <select id="langSelect" class="form-select form-select-sm w-auto"
          onchange="setLanguage(this.value)">
          <option value="th">TH</option>
          <option value="en">EN</option>
        </select>
      </div>
    </div>
  </div>

  <div class="container pb-5">

    <div class="glass-card p-3 mb-4">
      <form id="joinForm" class="d-flex gap-3 flex-column flex-md-row">
        <input name="name"
          id="playerNameInput"
          class="form-control form-control-lg rounded-4"
          placeholder="ชื่อคู่"
          data-i18n="join-queue-placeholder"
          required>

        <button class="btn btn-success action-btn" type="submit" data-i18n="join-queue-btn">
          <i class="bi bi-plus-lg"></i>
          เพิ่มคู่
        </button>
      </form>
    </div>

    <div id="actionButtonsContainer" class="d-flex flex-wrap gap-3 mb-4 action-stack">

      <button class="btn btn-success action-btn"
        onclick="socket.emit('start-match', parseInt(courtId))"
        data-i18n="start-match-btn">
        เริ่มแมตช์
      </button>

      <button class="btn btn-warning action-btn"
        onclick="socket.emit('reset-match', parseInt(courtId))"
        data-i18n="reset-match-btn">
        รีเซ็ตแมตช์
      </button>

      <a href="/court/<%= court.id %>/clear-queue"
        class="btn btn-danger action-btn"
        onclick="return confirm(t('confirm-clear-queue'))"
        data-i18n="clear-queue-btn">
        ล้างคิวทั้งหมด
      </a>

      <a href="/court/<%= court.id %>/history/clear"
        class="btn btn-outline-danger action-btn"
        onclick="return confirm(t('confirm-clear-history'))"
        data-i18n="clear-history-btn">
        ล้างประวัติ
      </a>

      <a href="/court/<%= court.id %>/undo"
        class="btn btn-outline-secondary action-btn"
        onclick="return confirm(t('confirm-undo'))"
        data-i18n="undo-btn">
        ย้อนกลับ
      </a>
    </div>

    <div class="glass-card p-4 mb-4 position-relative">

      <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h4 class="fw-bold mb-0">
          <span data-i18n="active-match-title">แมตช์ที่กำลังดำเนินอยู่</span>
        </h4>

        <div class="match-timer">
          <i class="bi bi-clock"></i>
          <span id="matchTimer">00:00</span>
        </div>
      </div>

      <div id="matchContainer">
        <div class="alert alert-secondary text-center rounded-4" data-i18n="court-empty">
          คอร์ทว่าง
        </div>
      </div>
    </div>

    <div class="glass-card overflow-hidden">

      <div class="d-flex justify-content-between align-items-center p-4 border-bottom flex-wrap gap-2">
        <h4 class="fw-bold mb-0" data-i18n="queue-title">คิว</h4>
        <div class="text-secondary">
          <span id="queueCount">0</span>
          <span data-i18n="queue-title-bar" data-i18n-value="<%= court.id %>">คู่</span>
        </div>
      </div>

      <div id="queueContainer">
        <div class="p-4 text-center text-secondary" data-i18n="queue-empty">
          คิวว่าง
        </div>
      </div>
    </div>

  </div>

  <script>
    const courtId = "<%= court.id %>";
    const socket = io();
    let draggedItem = null;
    let matchTimerInterval = null;
    let matchStartTimestamp = null;

    function formatDuration(ms) {
      if (!ms || ms < 0) ms = 0;
      const totalSeconds = Math.floor(ms / 1000);
      const minutes = Math.floor(totalSeconds / 60);
      const seconds = totalSeconds % 60;
      return `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
    }

    function startMatchTimer(ts) {
      stopMatchTimer();
      matchStartTimestamp = Number(ts) || Date.now();

      function tick() {
        document.getElementById('matchTimer').textContent = formatDuration(Date.now() - matchStartTimestamp);
      }

      tick();
      matchTimerInterval = setInterval(tick, 1000);
    }

    function stopMatchTimer() {
      if (matchTimerInterval) clearInterval(matchTimerInterval);
      document.getElementById('matchTimer').textContent = '00:00';
    }

    const url = `${location.origin}/court/${courtId}`;
    new QRCode(document.getElementById('courtQR'), {
      text: url,
      width: 72,
      height: 72
    });
    // Toggle QR code visibility when button clicked
    document.getElementById('showQRBtn').addEventListener('click', function() {
      const qr = document.getElementById('courtQR');
      if (qr.classList.contains('d-none')) {
        qr.classList.remove('d-none');
        this.textContent = 'Hide QR';
      } else {
        qr.classList.add('d-none');
        this.textContent = 'QR Code';
      }
    });

    socket.emit('join-court', courtId);

    socket.on(`court:${courtId}`, (data) => {
      updateMatchDisplay(data.match);
      updateQueueDisplay(data.queue);
      updateLiveIndicator();
    });

    document.getElementById('joinForm').addEventListener('submit', function(e) {
      e.preventDefault();

      const name = document.getElementById('playerNameInput').value.trim();
      if (!name) return;

      socket.emit('join-queue', {
        courtId: parseInt(courtId),
        name
      });

      document.getElementById('playerNameInput').value = '';
    });

    function updateMatchDisplay(match) {
      const container = document.getElementById('matchContainer');

      if (!match) {
        stopMatchTimer();

        container.innerHTML = `
          <div class="alert alert-secondary text-center rounded-4" data-i18n="court-empty">
            คอร์ทว่าง
          </div>
        `;

        applyTranslations();
        return;
      }

      startMatchTimer(match.timestamp);

      container.innerHTML = `
        <div class="row g-4 align-items-center">

          <div class="col-lg-5">
            <div class="team-panel team-green">
              <div class="fw-semibold text-success">${t('team-a') || 'ทีม A'}</div>
              <div class="fs-2 fw-bold">${escapeHtml(match.teamA)}</div>

              <div class="text-secondary mt-2" data-i18n="played-rounds" data-i18n-value="${match.matchesPlayedA}">
                ${t('played-rounds') || 'รอบที่เล่น'}: ${match.matchesPlayedA}
              </div>

              <div class="score-row">
                <button class="btn btn-outline-success score-btn"
                  onclick="socket.emit('${match.matchesPlayedA === 0 ? 'add-match' : 'minus-match'}', { courtId: parseInt(courtId), side: 'A' })">
                  ${match.matchesPlayedA === 0 ? '+1' : '-1'}
                </button>

              </div>

              <button class="btn btn-success w-100 action-btn"
                onclick="socket.emit('end-match', { courtId: parseInt(courtId), winner: 'A' })"
                data-i18n="win-a-btn">
                ทีม A ชนะ
              </button>
            </div>
          </div>

          <div class="col-lg-2 text-center fw-bold text-secondary fs-4">
            VS
          </div>

          <div class="col-lg-5">
            <div class="team-panel team-red">
              <div class="fw-semibold text-danger">${t('team-b') || 'ทีม B'}</div>
              <div class="fs-2 fw-bold">${escapeHtml(match.teamB)}</div>

              <div class="text-secondary mt-2" data-i18n="played-rounds" data-i18n-value="${match.matchesPlayedB}">
                ${t('played-rounds') || 'รอบที่เล่น'}: ${match.matchesPlayedB}
              </div>

              <div class="score-row">
                <button class="btn btn-outline-danger score-btn"
                  onclick="socket.emit('${match.matchesPlayedB === 0 ? 'add-match' : 'minus-match'}', { courtId: parseInt(courtId), side: 'B' })">
                  ${match.matchesPlayedB === 0 ? '+1' : '-1'}
                </button>

              </div>

              <button class="btn btn-danger w-100 action-btn"
                onclick="socket.emit('end-match', { courtId: parseInt(courtId), winner: 'B' })"
                data-i18n="win-b-btn">
                ทีม B ชนะ
              </button>
            </div>
          </div>
        </div>
      `;

      applyTranslations();
    }

    function updateQueueDisplay(queue) {
      const container = document.getElementById('queueContainer');
      document.getElementById('queueCount').textContent = queue?.length || 0;

      if (!queue || queue.length === 0) {
        container.innerHTML = `
          <div class="p-4 text-center text-secondary" data-i18n="queue-empty">
            คิวว่าง
          </div>
        `;

        applyTranslations();
        return;
      }

      container.innerHTML = queue.map((q, i) => `
        <div class="queue-item" data-queue-id="${q.id}">
          <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">

            <div class="d-flex align-items-center gap-3">
              <i class="bi bi-grip-vertical drag-handle" draggable="true"></i>
              <strong>${i + 1}</strong>

              <div>
                <div id="name-text-${q.id}" class="fw-semibold">${escapeHtml(q.name)}</div>

                <form id="edit-form-${q.id}" class="d-none mt-2"
                  onsubmit="handleRenameSubmit(event, '${q.id}')">

                  <div class="d-flex gap-2">
                    <input name="name"
                      value="${escapeHtml(q.name)}"
                      class="form-control form-control-sm"
                      required>

                    <button class="btn btn-sm btn-success">
                      OK
                    </button>
                  </div>
                </form>
              </div>
            </div>

            <div class="d-flex align-items-center gap-3 flex-wrap">

              <span class="pill" data-i18n="estimated-min" data-i18n-value="${q.estimatedStartMinutes || 0}">
                ~${q.estimatedStartMinutes || 0} นาที
              </span>

              <button id="edit-btn-${q.id}"
                class="btn btn-sm btn-light border"
                onclick="enableEdit('${q.id}')">
                <i class="bi bi-pencil"></i>
              </button>

              <button class="btn btn-sm btn-light border text-danger"
                onclick="removeQueue(${q.id})">
                <i class="bi bi-x-lg"></i>
              </button>
            </div>
          </div>
        </div>
      `).join('');

      setupDragAndDrop();
    }

    function setupDragAndDrop() {
  const items = document.querySelectorAll('.queue-item');

  items.forEach(item => {
    const handle = item.querySelector('.drag-handle');

    // Desktop drag events
    handle.addEventListener('dragstart', () => {
      draggedItem = item;
      item.classList.add('dragging');
    });
    handle.addEventListener('dragend', () => {
      item.classList.remove('dragging');
      items.forEach(i => i.classList.remove('drag-over'));
      sendQueueOrder();
    });
    item.addEventListener('dragover', e => {
      e.preventDefault();
      if (item !== draggedItem) item.classList.add('drag-over');
    });
    item.addEventListener('dragleave', () => {
      item.classList.remove('drag-over');
    });
    item.addEventListener('drop', e => {
      e.preventDefault();
      if (item !== draggedItem) {
        const allItems = [...document.querySelectorAll('.queue-item')];
        const draggedIndex = allItems.indexOf(draggedItem);
        const targetIndex = allItems.indexOf(item);
        if (draggedIndex < targetIndex) {
          item.parentNode.insertBefore(draggedItem, item.nextSibling);
        } else {
          item.parentNode.insertBefore(draggedItem, item);
        }
      }
      item.classList.remove('drag-over');
    });

    // Mobile touch events
    let touchMoveHandler = null;
    handle.addEventListener('touchstart', e => {
      e.preventDefault();
      draggedItem = item;
      item.classList.add('dragging');
    });
    handle.addEventListener('touchend', e => {
      e.preventDefault();
      item.classList.remove('dragging');
      items.forEach(i => i.classList.remove('drag-over'));
      sendQueueOrder();
    });
    handle.addEventListener('touchmove', e => {
      e.preventDefault();
      const touch = e.touches[0];
      const targetElem = document.elementFromPoint(touch.clientX, touch.clientY);
      const targetItem = targetElem && targetElem.closest('.queue-item');
      if (targetItem && targetItem !== draggedItem) {
        const allItems = [...document.querySelectorAll('.queue-item')];
        const draggedIndex = allItems.indexOf(draggedItem);
        const targetIndex = allItems.indexOf(targetItem);
        if (draggedIndex < targetIndex) {
          targetItem.parentNode.insertBefore(draggedItem, targetItem.nextSibling);
        } else {
          targetItem.parentNode.insertBefore(draggedItem, targetItem);
        }
      }
    });
  });
}
      const items = document.querySelectorAll('.queue-item');

      items.forEach(item => {
        const handle = item.querySelector('.drag-handle');

        handle.addEventListener('dragstart', () => {
          draggedItem = item;
          item.classList.add('dragging');
        });

        handle.addEventListener('dragend', () => {
          item.classList.remove('dragging');
          items.forEach(i => i.classList.remove('drag-over'));
        });

        item.addEventListener('dragover', e => {
          e.preventDefault();
          if (item !== draggedItem) item.classList.add('drag-over');
        });

        item.addEventListener('dragleave', () => {
          item.classList.remove('drag-over');
        });

        item.addEventListener('drop', e => {
          e.preventDefault();

          if (item !== draggedItem) {
            const allItems = [...document.querySelectorAll('.queue-item')];
            const draggedIndex = allItems.indexOf(draggedItem);
            const targetIndex = allItems.indexOf(item);

            if (draggedIndex < targetIndex) {
              item.parentNode.insertBefore(draggedItem, item.nextSibling);
            } else {
              item.parentNode.insertBefore(draggedItem, item);
            }

            sendQueueOrder();
          }

          item.classList.remove('drag-over');
        });
      });


    function sendQueueOrder() {
      const items = document.querySelectorAll('.queue-item');

      const newOrder = Array.from(items).map((item, index) => ({
        id: parseInt(item.dataset.queueId),
        position: index + 1
      }));

      fetch(`/court/${courtId}/reorder-queue`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ order: newOrder })
      });
    }

    function enableEdit(id) {
      document.getElementById(`name-text-${id}`).classList.add('d-none');
      document.getElementById(`edit-btn-${id}`).classList.add('d-none');
      document.getElementById(`edit-form-${id}`).classList.remove('d-none');
    }

    function handleRenameSubmit(e, queueId) {
      e.preventDefault();

      const form = e.target;
      const name = form.querySelector('input[name="name"]').value.trim();

      socket.emit('rename-queue', {
        courtId: parseInt(courtId),
        queueId: parseInt(queueId),
        name
      });
    }

    function removeQueue(queueId) {
      socket.emit('remove-queue', {
        courtId: parseInt(courtId),
        queueId: parseInt(queueId)
      });
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function updateLiveIndicator() {
      document.getElementById('liveIndicator').style.background = '#22c55e';
    }

    socket.on('disconnect', () => {
      document.getElementById('liveIndicator').style.background = '#ef4444';
    });

    socket.on('connect', () => {
      document.getElementById('liveIndicator').style.background = '#22c55e';
      socket.emit('join-court', courtId);
    });
  </script>

  <script src="/js/i18n.js?v=<%= APP_VERSION %>"></script>
</body>

</html>